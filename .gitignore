# scripts/md2post.py — only the generated HTML is committed.
*.md

# …except the example template and this project's README
!README.md
!blog/post-template.md

# ── Misc ──────────────────────────────────────────────────
*.log
*.bak
*.tmp
*.orig
.env
.env.*
